<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="diplomdemo.AddProductWindow"
        Title="Добавление товара" Height="800" Width="600">
    <StackPanel Spacing="10">
        <TextBox Name="ProductName" Watermark="Название товара"/>
        <AutoCompleteBox Name="ProductType" Watermark="Тип товара" FilterMode="StartsWith"/>
        <ComboBox Name="ProductSize" PlaceholderText="Размер"/>
        <TextBox Name="ProductQuantity" Watermark="Количество"/>
        <TextBox Name="ProductCost" Watermark="Стоимость"/>
        <AutoCompleteBox Name="ProductFandom" Watermark="Фандом"/>
        <TextBox Name="ProductSale" Watermark="Скидка (%)"/>
        <Button Click="AddPhotoClick" Content="Добавить фотографию"/>
        <Image Name="PhotoImage" Height="150"/>
        <Button Content="Добавить товар" Click="AddProduct_Click"/>
    </StackPanel>
</Window>
