<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="diplomdemo.RegWin"
        Title="RegWin"
		>
	<DockPanel>
		<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
			<TextBlock> Регистрация:</TextBlock>
			<ComboBox Name="RoleBox"
					  Height="40" Width="200"
					  PlaceholderText="Роль"></ComboBox>
			<TextBox Name="NameBox"
					 Height="40" Width="200"
					 Watermark="Имя"></TextBox>
			<TextBox Name="PhoneBox"
					 Height="40" Width="200"
					 Watermark="Телефон"></TextBox>
			<TextBox Name="LoginBox"
					 Height="40" Width="200"
					 Watermark="Логин"></TextBox>
			<TextBox Name="PasswordBox"
					 Height="40" Width="200"
					 Watermark="Пароль"></TextBox>
			<Button
				HorizontalAlignment="Center"
				Name="SaveUser" 
				Click="Save_Click"
				Content="Сохранить">
			</Button>
		</StackPanel>
	</DockPanel>
</Window>
