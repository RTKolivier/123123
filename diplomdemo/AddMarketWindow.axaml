<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="diplomdemo.AddMarketWindow"
        Title="AddMarketWindow">
    <DockPanel Margin="15">
        <Button Click="BackClick" Content="Назад"/>
        <StackPanel Spacing="10">
            <TextBox Watermark="Название маркета" Name="MarketBox"/>
            <DatePicker Name="DatePicker"/></StackPanel>
        <Button Content="Сохранить" Click="SaveClick"/>
    </DockPanel>
</Window>
