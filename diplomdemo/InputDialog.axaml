<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="diplomdemo.InputDialog"
        Title="Пополнение товара" Height="200" Width="300">
        <StackPanel Spacing="10">
                <TextBlock Name="PromptText" Margin="0,0,0,10"/>
                <TextBox Name="QuantityInput" Watermark="Количество"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="ОК" Click="Ok_Click" Width="75" Margin="0,0,10,0"/>
                        <Button Content="Отмена" Click="Cancel_Click" Width="75"/>
                </StackPanel>
        </StackPanel>
</Window>
